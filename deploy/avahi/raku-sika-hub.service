<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">

<!-- mDNS service definition for raku-sika-hub
     Install: sudo cp deploy/avahi/raku-sika-hub.service /etc/avahi/services/
     This makes the Pi discoverable as "raku-sika-hub.local" on the LAN.
-->
<service-group>
  <name replace-wildcards="no">raku-sika-hub</name>

  <service>
    <type>_http._tcp</type>
    <port>19800</port>
    <txt-record>path=/</txt-record>
    <txt-record>service=raku-sika-hub</txt-record>
  </service>
</service-group>
